---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProductListing from "../../components/ProductListing.astro";
import { getProducts } from "../../data/pocketbase";

const products = await getProducts();
---

<BaseLayout
  locale="en"
  title="Product Center | Zhongyan"
  description="Browse PET and PP blow molding machines by capacity, material and output."
>
  <ProductListing products={products} locale="en" />
</BaseLayout>
