---
import BaseLayout from "../layouts/BaseLayout.astro";
import HomePage from "../components/HomePage.astro";
import { getFeaturedProducts } from "../data/products";
import { getProducts } from "../data/pocketbase";

const products = await getProducts();
const featuredProducts = getFeaturedProducts(products);
---

<BaseLayout
  locale="en"
  title="Zhongyan Intelligent Equipment | PET & PP Blow Molding Machines"
  description="PET and PP blow molding machines, model selection support and complete line solutions for global bottle production."
>
  <HomePage locale="en" featuredProducts={featuredProducts} />
</BaseLayout>
