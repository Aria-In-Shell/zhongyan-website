---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ProductDetail from "../../../components/ProductDetail.astro";
import { getProductText, getRelatedProducts } from "../../../data/products";
import { getProducts } from "../../../data/pocketbase";

export async function getStaticPaths() {
  const products = await getProducts();
  return products.map((product) => ({
    params: { id: product.id },
    props: { product, relatedProducts: getRelatedProducts(product, products) }
  }));
}

const { product, relatedProducts } = Astro.props;
const text = getProductText(product, "zh");
---

<BaseLayout locale="zh" title={`${text.name} | 中研智能装备`} description={text.sellingPoint} ogImage={product.image}>
  <ProductDetail product={product} relatedProducts={relatedProducts} locale="zh" />
</BaseLayout>
